import {
  "moonbitlang/async",
  "mizchi/bit_core" @bit,
  "mizchi/bit_object" @object,
  "mizchi/bit_types" @types,
  "mizchi/bit_lib" @bitlib,
  "mizchi/bit_utils" @string_utils,
  "mizchi/bit_runtime" @runtime,
  "mizchi/bit_osfs" @osfs,
  "mizchi/llm" @llmlib,
  "mizchi/llm/openai",
  "mizchi/llm/ffi" @llm_ffi,
  "moonbitlang/async/process",
  "moonbitlang/core/encoding/utf8",
  "moonbitlang/core/json",
  "moonbitlang/core/strconv",
  "moonbitlang/core/env",
  "moonbitlang/x/sys",
}

warnings = "-29"

import {
  "moonbitlang/core/test",
} for "wbtest"

options(
  targets: {
    "rebase_ai.mbt": [ "native" ],
    "rebase_ai_wbtest.mbt": [ "native" ],
  },
)
