name = "mizchi/bit_remote"

version = "0.45.4"

import {
  "mizchi/bit_core@0.45.4",
  "mizchi/bit_io@0.45.4",
  "mizchi/bit_object@0.45.4",
  "mizchi/bit_types@0.45.4",
