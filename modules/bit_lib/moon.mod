name = "mizchi/bit_lib"

version = "0.45.0"

import {
  "mizchi/bit_core@0.45.0",
  "mizchi/bit_date@0.45.0",
  "mizchi/bit_diff3@0.45.0",
  "mizchi/bit_diff_core@0.45.0",
  "mizchi/bit_hash@0.45.0",
  "mizchi/bit_ignore@0.45.0",
  "mizchi/bit_io@0.45.0",
  "mizchi/bit_io_native@0.45.0",
  "mizchi/bit_object@0.45.0",
  "mizchi/bit_osfs@0.45.0",
  "mizchi/bit_pack@0.45.0",
  "mizchi/bit_protocol@0.45.0",
  "mizchi/bit_refs@0.45.0",
  "mizchi/bit_reftable@0.45.0",
  "mizchi/bit_remote@0.45.0",
  "mizchi/bit_repo@0.45.0",
  "mizchi/bit_types@0.45.0",
  "mizchi/bit_utils@0.45.0",
