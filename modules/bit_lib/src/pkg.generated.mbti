  commit_id : @bit_object.ObjectId?
  conflicts : Array[String]
}

pub struct RebaseState {
  onto : @bit_object.ObjectId
  orig_head : @bit_object.ObjectId
  head_name : String
  todo : Array[@bit_object.ObjectId]
  done : Array[@bit_object.ObjectId]
  current : @bit_object.ObjectId?
  message : String
  author : String
  author_time : Int64
  author_tz : String
}

pub enum RebaseStatus {
  Complete
  Conflict
  NothingToRebase
}

pub(all) struct ReceivePackProcResult {
  refname : String
  original_refname : String
  old_id : String
  new_id : String
  status : String
  message : String
  fall_through : Bool
}

pub(all) struct ReceivePackRequest {
  updates : Array[RefUpdate]
  capabilities : Array[String]
  pack : Bytes
  push_options : Array[String]
  cert_push_options : Array[String]
  has_push_cert : Bool
}

pub(all) struct ReceivePackResult {
  updated : Array[String]
  rejected : Array[(String, String)]
  unpack_error : String?
  connectivity_error_oid : String?
}

pub(all) struct RefUpdate {
  old_id : @bit_object.ObjectId
  new_id : @bit_object.ObjectId
  refname : String
}

pub struct ReflogEntry {
  old_id : @bit_object.ObjectId
  new_id : @bit_object.ObjectId
  author : String
  email : String
  timestamp : Int64
  timezone : String
  message : String
}

pub(all) struct RemoteConfig {
  mut urls : Array[String]
  mut pushurls : Array[String]
  mut fetch : Array[String]
  mut push : Array[String]
  mut promisor : Bool
  mut partial_clone_filter : String?
  mut mirror : Bool
  mut tagopt : String?
}

pub enum RemoteHeadState {
  Missing
  Detached(String)
  Symref(String)
  Other(String)
}

pub struct RepackResult {
  pack_id : @bit_object.ObjectId
  object_count : Int
  pack_bytes : Int
}

pub(all) enum ResetMode {
  Soft
  Mixed
  Hard
}

pub struct ResolveUndoEntry {
  path : String
  base : ResolveUndoStage?
  ours : ResolveUndoStage?
  theirs : ResolveUndoStage?
}

pub struct ResolveUndoStage {
  mode : Int
  id : @bit_object.ObjectId
}

pub struct StashEntry {
  id : @bit_object.ObjectId
  message : String
}

pub(all) struct StashPatchHunk {
  path : String
  display_lines : Array[String]
}

pub struct Status {
  staged_added : Array[String]
  staged_modified : Array[String]
  staged_deleted : Array[String]
  unstaged_modified : Array[String]
  unstaged_deleted : Array[String]
  untracked : Array[String]
}

pub enum TextAttr {
  Auto
  Set
  Unset
  Unspecified
}

pub enum TodoCommand {
  Pick
  Reword
  Edit
  Squash
  Fixup
  Drop
  Exec
  Break
  Label
  Reset
  Merge
} derive(Eq, @debug.Debug)
pub impl Show for TodoCommand

pub struct TreeFileEntry {
  id : @bit_object.ObjectId
  mode : Int
}

pub(all) struct UploadPackConfig {
  allow_filter : Bool
  blob_packfile_uri : String?
  allow_ref_in_want : Bool
}
pub fn UploadPackConfig::default() -> Self
pub fn UploadPackConfig::new(Bool, String?, Bool) -> Self

pub struct UploadPackRequest {
  wants : Array[@bit_object.ObjectId]
  haves : Array[@bit_object.ObjectId]
  capabilities : Array[String]
  done : Bool
  shallow : Array[@bit_object.ObjectId]
  deepen : Int?
}

pub struct UploadPackRequestV2 {
  command : String
  capabilities : Array[String]
  wants : Array[@bit_object.ObjectId]
  want_refs : Array[String]
  haves : Array[@bit_object.ObjectId]
  done : Bool
  filter : String?
  packfile_uris : String?
}

pub(all) struct WorktreeInfo {
  path : String
  head_id : @bit_object.ObjectId?
  branch : String?
  locked : Bool
  is_main : Bool
  is_bare : Bool
}

pub(all) struct WorktreeRepairResult {
  repaired : Array[String]
  warnings : Array[String]
} derive(Eq, @debug.Debug)

// Type aliases

// Traits
pub(open) trait Clock {
  fn now(Self) -> Int64
}

pub(open) trait ObjectStore {
  fn get(Self, @bit_object.ObjectId) -> @bit_object.PackObject? raise @bit_object.GitError
  fn put(Self, @bit_object.ObjectType, Bytes) -> @bit_object.ObjectId raise @bit_object.GitError
  fn has(Self, @bit_object.ObjectId) -> Bool raise @bit_object.GitError
}

pub(open) trait Random {
  fn short(Self) -> String
}

pub(open) trait RefStore {
  fn resolve(Self, String) -> @bit_object.ObjectId? raise @bit_object.GitError
  fn update(Self, String, @bit_object.ObjectId?) -> Unit raise @bit_object.GitError
  fn list(Self, String) -> Array[String] raise @bit_object.GitError
}

pub(open) trait Transport {
  fn fetch(Self, String, Array[@bit_object.ObjectId]) -> Bytes raise @bit_object.GitError
  fn push(Self, String, Array[PushUpdate]) -> Result[Unit, String] raise @bit_object.GitError
}

pub(open) trait WorkingTree {
  fn read_file(Self, String) -> Bytes raise @bit_object.GitError
  fn write_file(Self, String, Bytes) -> Unit
  fn remove_file(Self, String) -> Unit
  fn is_file(Self, String) -> Bool
  fn is_dir(Self, String) -> Bool
  fn readdir(Self, String) -> Array[String] raise @bit_object.GitError
  fn is_dirty(Self) -> Bool
  fn rollback(Self) -> Unit
  fn get_working_files(Self) -> Array[String]
  fn snapshot(Self, String, String, Int64) -> @bit_object.ObjectId raise @bit_object.GitError
  fn checkout(Self, @bit_object.ObjectId) -> Unit raise @bit_object.GitError
}

