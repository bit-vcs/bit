import {
  "moonbitlang/core/encoding/utf8" @utf8,
  "moonbitlang/x/crypto" @crypto,
}

import {
  "moonbitlang/core/bench" @bench,
} for "test"

warnings = "-29"

options(
  "native-stub": [ "sha1_ni.c", "sha256_ni.c" ],
  "cc-flags": [ "-msha", "-msse4.1" ],
  targets: {
    "sha1_ni_ffi.mbt": [ "native" ],
    "bench_test.mbt": [ "native" ],
  },
)
