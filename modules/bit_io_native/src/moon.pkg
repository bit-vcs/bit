import {
  "mizchi/bit_core" @bit,
  "mizchi/bit_object" @object,
  "mizchi/bit_types" @types,
  "mizchi/bit_repo" @repo,
  "mizchi/bit_io" @bitio,
  "mizchi/bit_pack" @pack,
  "mizchi/bit_protocol" @protocol,
  "moonbitlang/async",
  "moonbitlang/async/fs" @afs,
  "moonbitlang/async/http",
  "moonbitlang/async/process",
  "moonbitlang/core/encoding/utf8",
  "moonbitlang/core/env",
  "moonbitlang/x/codec/base64",
  "moonbitlang/x/fs",
  "moonbitlang/x/sys",
}

import {
  "moonbitlang/core/test",
} for "wbtest"

warnings = "-29"

options(
  "native-stub": [ "lstat_stub.c", "readdir_stub.c" ],
  targets: {
    "env_native.mbt": [ "native" ],
    "http_client_native.mbt": [ "native" ],
    "init_native.mbt": [ "native" ],
    "remote.mbt": [ "native" ],
    "upload_pack_http.mbt": [ "native" ],
    "upload_pack_http_common.mbt": [ "native", "js" ],
    "upload_pack_http_common_wbtest.mbt": [ "native" ],
    "upload_pack_process.mbt": [ "native" ],
    "upload_pack_process_wbtest.mbt": [ "native" ],
    "upload_pack_remote_native.mbt": [ "native" ],
    "worktree_probe_native.mbt": [ "native" ],
  },
)
