name = "mizchi/bit_protocol"

version = "0.43.1"

import {
  "mizchi/bit_core@0.43.1",
  "mizchi/bit_object@0.43.1",
  "mizchi/bit_io@0.43.1",
  "mizchi/bit_repo@0.43.1",
  "mizchi/bit_types@0.43.1",
  "mizchi/bit_pack@0.43.1",
  "moonbitlang/async@0.19.4",
}

repository = "https://github.com/mizchi/bit-vcs"

license = "Apache-2.0"

keywords = [ "git", "protocol", "transport" ]

description = "Git wire protocol + transport (gix-protocol + gix-transport)"

source = "src"

preferred_target = "native"